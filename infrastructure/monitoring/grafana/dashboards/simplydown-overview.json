{
  "dashboard": {
    "id": null,
    "title": "SAB Production Overview",
    "tags": ["sab", "production"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Job Submission Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(sab_jobs_submitted_total[5m])",
            "legendFormat": "Jobs/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Job Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(sab_jobs_completed_total[5m]) / (rate(sab_jobs_completed_total[5m]) + rate(sab_jobs_failed_total[5m])) * 100",
            "legendFormat": "Success %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 90},
                {"color": "green", "value": 95}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Active Jobs",
        "type": "stat",
        "targets": [
          {
            "expr": "simplydown_jobs_running_total",
            "legendFormat": "Running"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 20}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Queue Size",
        "type": "stat",
        "targets": [
          {
            "expr": "simplydown_jobs_queued_total",
            "legendFormat": "Queued"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Job Processing Timeline",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(simplydown_jobs_submitted_total[5m])",
            "legendFormat": "Submitted"
          },
          {
            "expr": "rate(simplydown_jobs_completed_total[5m])",
            "legendFormat": "Completed"
          },
          {
            "expr": "rate(simplydown_jobs_failed_total[5m])",
            "legendFormat": "Failed"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "Response Time Distribution",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "99th percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Queue Depth by Priority",
        "type": "timeseries",
        "targets": [
          {
            "expr": "simplydown_queue_size{priority=\"HIGH\"}",
            "legendFormat": "High Priority"
          },
          {
            "expr": "simplydown_queue_size{priority=\"NORMAL\"}",
            "legendFormat": "Normal Priority"
          },
          {
            "expr": "simplydown_queue_size{priority=\"LOW\"}",
            "legendFormat": "Low Priority"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "Dead Letter Queue",
        "type": "stat",
        "targets": [
          {
            "expr": "simplydown_jobs_dlq_total",
            "legendFormat": "DLQ Size"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16}
      },
      {
        "id": 9,
        "title": "Retry Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(simplydown_jobs_retried_total[5m])",
            "legendFormat": "Retries/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "15s"
  }
}
