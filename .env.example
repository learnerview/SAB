# SimplyDone Environment Configuration Example
# Copy this file to .env and replace placeholder values

# Application Configuration
SPRING_PROFILES_ACTIVE=api,worker,ui
PORT=8080

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/simplydone
SPRING_DATASOURCE_USERNAME=simplydone
SPRING_DATASOURCE_PASSWORD=your_strong_database_password_here

# Redis Configuration
REDIS_URL=redis://redis:6379
SIMPLYDONE_REDIS_PASSWORD=your_strong_redis_password_here

# Security Configuration
JWT_SECRET=your_strong_random_jwt_secret_here
API_KEY_ENCRYPTION_KEY=your_strong_encryption_key_here

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=simplydone
OTEL_RESOURCE_ATTRIBUTES=service.version=2.0.0,service.namespace=simplydone

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_strong_grafana_password_here

# TLS/SSL Configuration (for production)
TLS_DOMAIN=your-domain.com
TLS_EMAIL=admin@your-domain.com
PKCS12_PASSWORD=your_keystore_password_here

# Backup Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=simplydone
DB_USER=simplydone
DB_PASSWORD=your_strong_database_password_here
BACKUP_DIR=/backups

# Testing Configuration
BASE_URL=https://your-domain.com
ADMIN_API_KEY=your_admin_api_key_here
